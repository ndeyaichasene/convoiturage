@startuml sequence_rechercher_trajet
actor Passager as P
participant "IHM : passager-recherche.html" as UI1
participant "SystemeRecherche" as SYS
participant "Trajet (BDD)" as T
participant "IHM : passager-resultats.html" as UI2

P -> UI1 : saisir ville départ + arrivée + date
UI1 -> SYS : rechercherTrajets(depart, arrivee, date)
SYS -> T : filtrer(depart, arrivee, date, status="planifié")
activate T
T -> T : exclureTrajetsComplets()
T --> SYS : listeTrajets
deactivate T

alt aucun résultat
    SYS --> UI2 : listeVide
    UI2 --> P : afficher "Aucun trajet trouvé"
else résultats trouvés
    SYS --> UI2 : listeTrajets
    UI2 --> P : afficher les trajets disponibles
end
@enduml