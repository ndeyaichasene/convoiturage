@startuml sequence_demarrer_trajet
actor Conducteur as C
participant "IHM : conducteur-trajets.html" as UI
participant "SystemeGestion" as SYS
participant "Trajet (BDD)" as T
participant "Passager" as P

C -> UI : cliquer "Démarrer le trajet"
UI -> SYS : demarrerTrajet(trajetId)
SYS -> T : getStatus(trajetId)
activate T
T --> SYS : status
deactivate T

alt status != "planifié"
    SYS --> UI : erreurStatutInvalide
    UI --> C : afficher message d'erreur
else status == "planifié"
    SYS -> T : mettreAJourStatus("en cours")
    activate T
    T --> SYS : ok
    deactivate T
    SYS -> P : notifierDepart(trajetId)
    SYS --> UI : confirmationDemarrage
    UI --> C : afficher statut "En cours"
end
@enduml