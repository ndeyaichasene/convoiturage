@startuml sequence_terminer_trajet
actor Conducteur as C
participant "IHM : conducteur-trajets.html" as UI
participant "SystemeGestion" as SYS
participant "Trajet (BDD)" as T
participant "SystemeBancaire" as SB

C -> UI : cliquer "Terminer le trajet"
UI -> SYS : terminerTrajet(trajetId)
SYS -> T : getStatus(trajetId)
activate T
T --> SYS : status
deactivate T

alt status != "en cours"
    SYS --> UI : erreurStatutInvalide
    UI --> C : afficher message d'erreur
else status == "en cours"
    SYS -> T : mettreAJourStatus("terminé")
    activate T
    T --> SYS : ok
    deactivate T
    SYS -> SYS : calculerMontantAVerser()
    SYS -> SB : verserAuConducteur(conducteurId, montant)
    activate SB
    SB --> SYS : virementConfirme
    deactivate SB
    SYS --> UI : confirmationCloture
    UI --> C : afficher "Trajet clôturé — paiement versé"
end
@enduml